# ─────────────────────────────────────────────────
# ChampQR — Docker environment variables
# Copy this file and fill in real values before running:
#   cp .env.docker .env.docker.local
#   docker compose --env-file .env.docker.local up -d
# ─────────────────────────────────────────────────

# MongoDB credentials (used by both docker-compose and backend)
MONGO_INITDB_ROOT_USERNAME=champqr
MONGO_INITDB_ROOT_PASSWORD=change_this_mongo_password

# Redis password
REDIS_PASSWORD=change_this_redis_password

# JWT — MUST be changed in production (min 64 chars recommended)
JWT_SECRET=change_this_to_a_long_random_string_minimum_64_chars
JWT_EXPIRES_IN=7d

# Public URLs — update to your actual domain in production
FRONTEND_URL=http://localhost
FILE_BASE_URL=http://localhost/files

# Champions Ranch logo path inside the container
LOGO_PATH=/app/src/assets/champions-ranch-logo.png

# Optional: Resend (for password reset emails)
RESEND_API_KEY=

# Optional: OpenRouter (for AI features — Phase 2)
OPENROUTER_API_KEY=
