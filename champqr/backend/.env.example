PORT=3001
NODE_ENV=development

MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/champqr

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

REDIS_URL=redis://localhost:6379

FRONTEND_URL=http://localhost:5173

# File storage base URL (used to build public URLs for GridFS files)
FILE_BASE_URL=http://localhost:3001/files

# Champions Ranch logo path (absolute or relative to src/)
LOGO_PATH=./assets/champions-ranch-logo.png

# Optional: Resend for password reset emails
RESEND_API_KEY=

# Optional: OpenRouter for AI (Phase 2)
OPENROUTER_API_KEY=
